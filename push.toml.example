# 定时推送配置示例：复制为 push.toml 并填好后运行
#   xlh push              # 按 cron 常驻守护
#   xlh push --once       # 立即跑一次（测试用）
#
# 注意 TOML 语法：根级键 diagnose/diagnose_stocks 必须写在 [[holdings]]/[[stocks]]
# 之前，否则会被并入最后一个数组表。（也可直接用 Web「基金 → 推送」Tab 图形化配置）

# 额外只诊断、不持有的基金 / 股票（选填）
diagnose = ["110022"]
diagnose_stocks = ["000001"]

[schedule]
# 6 段 cron（含秒）：秒 分 时 日 月 周。示例：每个交易日 08:30:00
cron = "0 30 8 * * *"
# 仅在有新净值/行情时才推送（默认 true，天然规避周末/节假日空推）
only_on_new_data = true

[channel]
# 渠道：dingtalk | feishu | wework | serverchan
kind = "feishu"
# 群机器人 webhook 完整地址；serverchan 时填 sendkey（如 SCTxxxx）
webhook = "https://open.feishu.cn/open-apis/bot/v2/hook/换成你的"
# 钉钉/飞书「加签」密钥，留空则不加签（改用关键词/IP 白名单）
secret = ""
# 净值缓存目录（与回测共用）
cache_dir = ".cache"

# 组合总览（均选填，仅回显）
[portfolio]
total_amount = 30000
total_profit = 1800
cumulative_profit = 4200

# 基金持仓明细（可多条）
[[holdings]]
code = "161725"
amount = 12000
profit = 900

[[holdings]]
code = "005827"
amount = 10000
profit = 1200

# 股票持仓明细（可多条；A股/港股/美股代码）
[[stocks]]
code = "600519"
amount = 20000
profit = 1500
