# xlh 部署配置。复制为 .env 后按需修改：cp .env.example .env
#
# 持久状态根目录。数据库落在 ${XLH_STATE_DIR}/data/xlh.db。
#
#   /opt/xlh        ← 默认：与部署目录同一处，数据即 /opt/xlh/data
#   /srv/xlh-state  ← 更稳：在部署目录之外，任何部署动作都碰不到
#
# deploy.sh 只 scp 具体文件进部署目录（镜像包、compose、config），**从不 rm -rf、
# 从不整目录覆盖** —— 所以放 /opt/xlh 也不会因为部署而丢数据。
# 但风险不在脚本内：手工 `rm -rf /opt/xlh`、rsync --delete、或换别的部署工具，
# 都会连数据一起抹掉。想彻底免疫这类事故，就把它指到部署目录之外。
XLH_STATE_DIR=/opt/xlh

# 各子目录：
#   ${XLH_STATE_DIR}/data    ← xlh.db：用户/授权码/会话/推送配置/建议历史 **唯一不可再生**
#   ${XLH_STATE_DIR}/cache   ← 净值/K线/财报/估值缓存（可再生，但全量重抓很慢）
#   ${XLH_STATE_DIR}/output  ← 回测报告（可丢弃）
#   ${XLH_STATE_DIR}/backups ← 自动备份（每次部署前一份，保留最近 10 份）

# Web 监听。默认只绑回环，前面套 Nginx/Caddy 做 HTTPS 反代。
# 要直接对公网开放（不推荐），改成 0.0.0.0，并务必用安全组限制来源 IP。
XLH_BIND_ADDR=127.0.0.1
XLH_PORT=8080

# 时区：定时推送的 cron 按此解释。非北京时区请改这里，否则会差 8 小时。
TZ=Asia/Shanghai

# 镜像。用镜像仓库时改成 registry.example.com/you/xlh:1.2.3
XLH_IMAGE=xlh:latest
