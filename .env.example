# xlh 部署配置。复制为 .env 后按需修改：cp .env.example .env
#
# ⚠ 最重要的一条：XLH_STATE_DIR 必须在**部署目录之外**。
#
# 部署会覆盖 /opt/xlh（镜像、compose、config），但绝不会碰 XLH_STATE_DIR。
# 若把状态放在部署目录内（如 /opt/xlh/data），任何一次「清空重建 / 换目录 / 解包覆盖」
# 都会连数据一起抹掉 —— 这正是要避免的。

# 持久状态根目录（绝对路径，docker 之外的宿主机目录）
#   ${XLH_STATE_DIR}/data    ← 用户/授权码/会话/推送配置/建议历史（xlh.db）**唯一不可再生**
#   ${XLH_STATE_DIR}/cache   ← 行情缓存（可再生，但重抓很慢）
#   ${XLH_STATE_DIR}/output  ← 回测报告（可丢弃）
XLH_STATE_DIR=/srv/xlh-state

# Web 监听。默认只绑回环，前面套 Nginx/Caddy 做 HTTPS + 反代。
# 要直接对公网开放（不推荐），改成 0.0.0.0
XLH_BIND_ADDR=127.0.0.1
XLH_PORT=8080

# 时区：定时推送的 cron 按此解释。非北京时区请改这里。
TZ=Asia/Shanghai

# 镜像。用镜像仓库时改成 registry.example.com/you/xlh:1.2.3
XLH_IMAGE=xlh:latest
